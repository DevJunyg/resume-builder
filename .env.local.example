# Anthropic Claude API
ANTHROPIC_API_KEY=

# 앱 공개 URL (Vercel 배포 시 자동 설정됨)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── DB (AWS RDS PostgreSQL) — docs/db.md 참고 ───
# 예: postgresql://postgres:비밀번호@엔드포인트:5432/resumebuilder?sslmode=require
DATABASE_URL=

# ─── Auth.js (GitHub 로그인) — docs/db.md 참고 ───
# 생성: npx auth secret  또는  openssl rand -base64 32
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
